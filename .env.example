# WhatsApp customer support — international digits only, e.g. 2348012345678
NEXT_PUBLIC_WHATSAPP_NUMBER="2347039860446"

# Local testing: skip Paystack redirect/webhook (do not use in production)
CHECKOUT_SIMULATE_PAYMENT=true

# Set true only for local debugging — disables in-memory API/OTP rate limits
# RATE_LIMIT_DISABLED=true

# Paystack — https://dashboard.paystack.com/#/settings/developers (not needed when simulating)
PAYSTACK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_..."
# Required on Vercel — Paystack callback URL uses this (no trailing slash)
# NEXT_PUBLIC_APP_URL="https://ombre-six.vercel.app"
# Paystack webhook URL: https://your-domain.com/api/paystack/webhook

ADMIN_PASSWORD="your-secure-password"
ADMIN_SECRET="random-long-string-for-session-signing"

# Resend — https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"
RESEND_FROM="Ombré <onboarding@resend.dev>"

# Supabase — https://supabase.com/dashboard/project/_/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# Admin product/catalog photos → Supabase Storage bucket `product-images` (auto-created on first request)
# Secret keys section (sb_secret_...) — server only; never expose to the browser.
# RLS is enabled on shop tables with no anon policies — all data access goes through Next.js.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_your_key_here"
# Session pooler URI for automatic table creation (Supabase → Connect → Session pooler):
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres"
SUPABASE_DB_POOLER_REGION="eu-central-1"
# Or only the password — app builds the pooler URL (do not use db.*.supabase.co on Windows):
# SUPABASE_DB_PASSWORD="your-database-password"
